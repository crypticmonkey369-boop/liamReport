# Server Configuration
PORT=3000
PORTAL_PASSWORD=ChangeMeToAStrongPassword123!
COOKIE_SECRET=use-a-secure-random-string-for-cookie-signing

# Google API Credentials (for Google OAuth User Consent flow)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://profit-reporter-portal.onrender.com/oauth/callback/google
GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID

# Google Service Account Credentials (needed to sync tokens on server startup)
# (Paste the raw JSON content of your Google Service Account key file here as a single-line string)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Custom OAuth Proxy Configuration (Optional - set if routing Shopify/Meta/Klaviyo through a shared proxy)
# OAUTH_PROXY_URL=https://your-shared-oauth-proxy.com

# Shopify App Credentials (for client popup loops - if not using proxy)
SHOPIFY_CLIENT_ID=YOUR_SHOPIFY_CLIENT_ID
SHOPIFY_CLIENT_SECRET=YOUR_SHOPIFY_CLIENT_SECRET
SHOPIFY_REDIRECT_URI=https://profit-reporter-portal.onrender.com/oauth/callback/shopify

# Meta Ads API Credentials (for client popup loops - if not using proxy)
META_CLIENT_ID=YOUR_META_CLIENT_ID
META_CLIENT_SECRET=YOUR_META_CLIENT_SECRET
META_REDIRECT_URI=https://profit-reporter-portal.onrender.com/oauth/callback/meta

# Klaviyo App Credentials (for client popup loops - if not using proxy)
KLAVIYO_CLIENT_ID=YOUR_KLAVIYO_CLIENT_ID
KLAVIYO_CLIENT_SECRET=YOUR_KLAVIYO_CLIENT_SECRET
KLAVIYO_REDIRECT_URI=https://profit-reporter-portal.onrender.com/oauth/callback/klaviyo

# SMTP Server Configurations (Fallback Nodemailer email dispatching)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=sender@company.com
SMTP_PASS=YOUR_SMTP_APP_PASSWORD
SMTP_SECURE=true
SMTP_FROM="Profit Reporter" <sender@company.com>
